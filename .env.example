# Environment Configuration for Email Management System

# This file contains all environment variables needed for the email management system.
# Copy this file to .env.local and fill in your actual values.

# ==========================================
# SUPABASE CONFIGURATION
# ==========================================

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase Anon (public) Key
# WARNING: This is safe to expose in the frontend
VITE_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key...

# Supabase Service Role Key (for Edge Functions only)
# WARNING: KEEP THIS SECRET! Never expose in frontend!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your-service-key...

# ==========================================
# SENDGRID CONFIGURATION
# ==========================================

# Your SendGrid API Key
# WARNING: Keep this secret! Use only in Edge Functions!
SENDGRID_API_KEY=SG.your-sendgrid-api-key...

# Optional: Sender verification email for SendGrid
# This should be a verified sender in your SendGrid account
SENDGRID_VERIFIED_SENDER=noreply@yourdomain.com

# ==========================================
# SMTP CONFIGURATION (Alternative to SendGrid)
# ==========================================

# Uncomment and configure if using SMTP instead of SendGrid

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=true
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================

# Environment: development, staging, production
NODE_ENV=development

# Application name
APP_NAME=Email Management System

# Maximum recipients per batch
MAX_RECIPIENTS_PER_BATCH=50

# Maximum retries for failed emails
MAX_RETRIES=3

# Retry delay in milliseconds
RETRY_DELAY_MS=1000

# Request timeout in milliseconds
REQUEST_TIMEOUT_MS=30000

# ==========================================
# SECURITY CONFIGURATION
# ==========================================

# JWT Secret for authentication (optional, for enhanced security)
# JWT_SECRET=your-jwt-secret-key

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ==========================================
# EMAIL CONFIGURATION
# ==========================================

# Default sender email
DEFAULT_SENDER_EMAIL=noreply@yourdomain.com

# Default sender name
DEFAULT_SENDER_NAME=Email System

# Email reply-to address
REPLY_TO_EMAIL=support@yourdomain.com

# Support email for feedback/issues
SUPPORT_EMAIL=support@yourdomain.com

# ==========================================
# FEATURE FLAGS
# ==========================================

# Enable/disable features
FEATURE_TEMPLATES=true
FEATURE_CAMPAIGNS=true
FEATURE_CONTACT_GROUPS=true
FEATURE_SCHEDULED_SENDING=false
FEATURE_AUTO_REPLY=false

# ==========================================
# LOGGING & MONITORING
# ==========================================

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# Enable request logging
LOG_REQUESTS=true

# Enable error reporting (Sentry, etc.)
# SENTRY_DSN=https://key@sentry.io/project

# ==========================================
# NOTES
# ==========================================

# 1. How to get Supabase credentials:
#    - Visit https://app.supabase.com
#    - Select your project
#    - Go to Settings > API to find URL and Keys
#    - VITE_SUPABASE_ANON_KEY is the "anon" key
#    - SUPABASE_SERVICE_ROLE_KEY is the "service_role" key

# 2. How to set up SendGrid:
#    - Sign up at https://sendgrid.com
#    - Go to Settings > API Keys
#    - Create a new API key
#    - Verify sender addresses at Sender Authentication

# 3. For Vercel deployment:
#    - Add these environment variables in Vercel project settings
#    - Use VITE_* prefix for frontend variables
#    - Use non-VITE_ prefix for backend/Edge Functions

# 4. For local development:
#    - Create .env.local file (git-ignored)
#    - Use same variable names
#    - Install Supabase CLI: npm install -g supabase
#    - Run: supabase start

# 5. Security best practices:
#    - Never commit .env files to git
#    - Add .env.local to .gitignore
#    - Rotate API keys regularly
#    - Use separate keys for development/production
#    - Always use HTTPS in production
